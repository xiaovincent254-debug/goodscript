local RunService = game:GetService("RunService")
local Players = game:GetService("Players")
local player = Players.LocalPlayer

local targetBoss = nil
local nextTargetTime = 0 -- Stores the time when we are allowed to find a new boss

-- Function to find the next available boss
local function findBoss()
    -- Only look for a boss if the 1-second cooldown has passed
    if tick() < nextTargetTime then return nil end

    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("Model") and obj.Name == "Boss" then
            local humanoid = obj:FindFirstChildOfClass("Humanoid")
            if humanoid and humanoid.Health > 0 then
                return obj
            end
        end
    end
    return nil
end

RunService.Heartbeat:Connect(function()
    local character = player.Character
    if not character then return end

    -- 1. Check if current target is still valid/alive
    if targetBoss then
        local hum = targetBoss:FindFirstChildOfClass("Humanoid")
        
        -- If the boss died or was removed
        if not hum or hum.Health <= 0 or not targetBoss:IsDescendantOf(workspace) then
            targetBoss = nil
            nextTargetTime = tick() + 1 -- Start the 1-second wait timer
        end
    end

    -- 2. Look for a new target if we don't have one
    if not targetBoss then
        targetBoss = findBoss()
    end

    -- 3. Execution Phase
    if targetBoss then
        local humanoid = targetBoss:FindFirstChildOfClass("Humanoid")
        
        -- Teleport to Boss using Pivot
        character:PivotTo(targetBoss:GetPivot() * CFrame.new(0, 0, 3))

        -- Instantly set HP to 0 (Note: Only works if you have Network Ownership or the server allows it)
        if humanoid and humanoid.Health > 0 then
            humanoid.Health = 0
        end
    end
end)
