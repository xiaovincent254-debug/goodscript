local RunService = game:GetService("RunService")
local Players = game:GetService("Players")
local player = Players.LocalPlayer

local targetBoss = nil
local timeArrived = 0
local nextSearchTime = 0
local lockedYHeight = 0 -- Stores the height at the moment of teleport

local WAIT_BEFORE_KILL = 4  
local TRANSITION_DELAY = 2  

local function findBoss()
    if tick() < nextSearchTime then return nil end

    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("Model") and obj.Name == "Boss" then
            local humanoid = obj:FindFirstChildOfClass("Humanoid")
            if humanoid and humanoid.Health > 0 then
                return obj
            end
        end
    end
    return nil
end

RunService.Heartbeat:Connect(function()
    local character = player.Character
    local rootPart = character and character:FindFirstChild("HumanoidRootPart")
    if not character or not rootPart then return end

    -- 1. Target Acquisition
    if not targetBoss then
        targetBoss = findBoss()
        if targetBoss then
            timeArrived = tick()
            
            -- Capture the boss's current Y height (plus a small offset) 
            -- so you don't fall or float mid-teleport.
            lockedYHeight = targetBoss:GetPivot().Position.Y + 3 
        end
    end

    -- 2. Execution
    if targetBoss then
        local humanoid = targetBoss:FindFirstChildOfClass("Humanoid")
        
        -- Validity Check
        if not humanoid or humanoid.Health <= 0 or not targetBoss:IsDescendantOf(workspace) then
            targetBoss = nil
            nextSearchTime = tick() + TRANSITION_DELAY
            return
        end

        -- 3. Calculate the Locked-Height Position
        local bossPivot = targetBoss:GetPivot()
        local bossPos = bossPivot.Position
        
        -- Create a new CFrame using Boss X and Z, but the saved Locked Y
        -- We also keep the Boss's orientation so you face them
        local targetCFrame = CFrame.new(bossPos.X, lockedYHeight, bossPos.Z) 
                           * CFrame.Angles(0, math.rad(bossPivot:ToEulerAnglesYXZ()), 0)
                           * CFrame.new(0, 0, 3) -- Stay 3 studs away

        character:PivotTo(targetCFrame)

        -- 4. Timer Logic
        if tick() - timeArrived >= WAIT_BEFORE_KILL then
            humanoid.Health = 0
        end
    end
end)
