local RunService = game:GetService("RunService")
local Players = game:GetService("Players")
local player = Players.LocalPlayer

local targetBoss = nil

-- Efficiently find the next boss
local function findBoss()
    -- Note: GetDescendants can be heavy; use a specific folder if possible
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("Model") and obj.Name == "Boss" then
            local humanoid = obj:FindFirstChildOfClass("Humanoid")
            if humanoid and humanoid.Health > 0 then
                return obj
            end
        end
    end
    return nil
end

RunService.Heartbeat:Connect(function()
    local character = player.Character
    if not character then return end

    -- Validate or clear current target
    if targetBoss then
        local hum = targetBoss:FindFirstChildOfClass("Humanoid")
        if not hum or hum.Health <= 0 or not targetBoss:IsDescendantOf(workspace) then
            targetBoss = nil
        end
    end

    -- Target acquisition
    if not targetBoss then
        targetBoss = findBoss()
    end

    -- Execution
    if targetBoss then
        -- GetPivot() works even if parts are still streaming in
        local bossCFrame = targetBoss:GetPivot()
        
        -- Teleport your character to the boss's pivot location
        -- We add a small offset (3 studs back) so you don't glitch inside the model
        character:PivotTo(bossCFrame * CFrame.new(0, 0, 3))

        -- Clean up the head if it exists
        local head = targetBoss:FindFirstChild("Head")
        if head then
            head:Destroy()
        end
    end
end)
