local RunService = game:GetService("RunService")
local Workspace = game:GetService("Workspace")
local Players = game:GetService("Players")

local player = Players.LocalPlayer
local livingFolder = Workspace:FindFirstChild("Living")

-- Table to track state: [Model] = {spawnTime = number, processed = boolean}
local bossRegistry = {}

RunService.Heartbeat:Connect(function()
    local character = player.Character
    if not character or not character:FindFirstChild("HumanoidRootPart") then return end
    
    local hrp = character.HumanoidRootPart

    if not livingFolder then 
        livingFolder = Workspace:FindFirstChild("Living")
        return 
    end

    for _, entity in ipairs(livingFolder:GetChildren()) do
        pcall(function()
            if entity:IsA("Model") and entity.Name == "Boss" then
                local humanoid = entity:FindFirstChildOfClass("Humanoid")
                local head = entity:FindFirstChild("Head")

                -- If this is a new boss we haven't seen yet, start the 1s timer
                if not bossRegistry[entity] then
                    bossRegistry[entity] = {
                        spawnTime = tick(),
                        processed = false
                    }
                end

                local data = bossRegistry[entity]

                -- Only target if alive, has a head, and hasn't been processed yet
                if humanoid and head and humanoid.Health > 0 and not data.processed then
                    
                    -- Check if 1 second has passed since detection
                    if tick() - data.spawnTime >= 1 then
                        -- 1. Teleport to the model's current pivot
                        hrp.CFrame = entity:GetPivot()
                        
                        -- 2. Set health to 0 immediately
                        humanoid.Health = 0
                        
                        -- 3. Destroy the head for good measure
                        head:Destroy()
                        
                        -- Mark as processed so we don't loop on this specific instance again
                        data.processed = true 
                    end
                end
            end
        end)
    end

    -- Cleanup: Remove bosses from memory once they leave the folder (despawn/respawn)
    for boss, _ in pairs(bossRegistry) do
        if not boss:IsDescendantOf(livingFolder) then
            bossRegistry[boss] = nil
        end
    end
end)
