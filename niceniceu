local RunService = game:GetService("RunService")
local Players = game:GetService("Players")
local player = Players.LocalPlayer

local targetBoss = nil
local nextActionTime = 0 -- Cooldown tracker for the 2-second delay
local TELEPORT_DELAY = 2 -- Configurable delay in seconds

-- Function to find a valid boss
local function findBoss()
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("Model") and obj.Name == "Boss" then
            local humanoid = obj:FindFirstChildOfClass("Humanoid")
            if humanoid and humanoid.Health > 0 then
                return obj
            end
        end
    end
    return nil
end

RunService.Heartbeat:Connect(function()
    local character = player.Character
    if not character then return end

    -- 1. Target Validation
    if targetBoss then
        local hum = targetBoss:FindFirstChildOfClass("Humanoid")
        -- If boss is dead or gone, clear target
        if not hum or hum.Health <= 0 or not targetBoss:IsDescendantOf(workspace) then
            targetBoss = nil
        end
    end

    -- 2. Target Acquisition
    if not targetBoss then
        targetBoss = findBoss()
    end

    -- 3. The 2-Second Delayed Execution
    if targetBoss and tick() >= nextActionTime then
        local humanoid = targetBoss:FindFirstChildOfClass("Humanoid")
        
        -- Perform the teleport
        character:PivotTo(targetBoss:GetPivot() * CFrame.new(0, 0, 3))

        -- Set HP to 0
        if humanoid then
            humanoid.Health = 0
        end

        -- Set the cooldown for the next jump
        nextActionTime = tick() + TELEPORT_DELAY
    end
end)
